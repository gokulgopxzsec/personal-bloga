{
  "name": "blogapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node tools/quant-engine.mjs && node tools/ai-detection-shield.mjs ALL && next build --webpack && pagefind --site out",
    "build:fast": "next build --webpack && pagefind --site out",
    "start": "node tools/dashboard.mjs",
    "dashboard": "node tools/dashboard.mjs",
    "lint": "eslint",
    "test": "node --test tests/pipeline.test.mjs",
    "shield": "node tools/ai-detection-shield.mjs ALL",
    "quant": "node tools/quant-engine.mjs",
    "rank": "node tools/content-rank.mjs",
    "style": "node tools/style-learner.mjs",
    "index": "node tools/index-rag.mjs",
    "events": "node tools/orchestrator.mjs events",
    "autopilot": "node tools/orchestrator.mjs autopilot",
    "distribute": "node tools/backlink-agent.mjs",
    "generate": "node tools/generate-blog.mjs"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "pagefind": "^1.5.2",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
